<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Tesseract ships native x64 DLLs in runtimes/. Pinning to win-x64
         makes MSBuild copy them next to the executable on plain `dotnet build`. -->
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenCvSharp4" Version="4.10.0.20240616" />
    <PackageReference Include="OpenCvSharp4.Extensions" Version="4.10.0.20240616" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.10.0.20240616" />
    <PackageReference Include="Tesseract" Version="5.2.0" />
  </ItemGroup>

  <!-- Copy the OCR traineddata folder to the build output so Tesseract can
       find it at runtime (we look for ./tessdata/eng.traineddata next to the .exe). -->
  <ItemGroup>
    <None Include="tessdata\**\*.*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
